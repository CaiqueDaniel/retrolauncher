<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<fx:root prefHeight="400.0" prefWidth="600.0" type="HBox" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1">
    <Button fx:id="btnUpdate" mnemonicParsing="false" text="Atualizar">
        <font>
            <Font name="Segoe UI" size="14.0" />
        </font>
        <HBox.margin>
            <Insets right="16.0" />
        </HBox.margin>
    </Button>
    <Button fx:id="btnSettings" mnemonicParsing="false" text="Configurações">
        <font>
            <Font name="Segoe UI" size="14.0" />
        </font>
    </Button>
    <padding>
        <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
    </padding>
</fx:root>
