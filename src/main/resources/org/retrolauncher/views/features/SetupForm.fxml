<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.retrolauncher.gui.components.*?>

<fx:root alignment="CENTER_LEFT" layoutX="48.0" layoutY="48.0" prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #EFEFEF;" type="VBox" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1">

    <Label text="Configuração">
        <font>
            <Font size="26.0" />
        </font>
        <opaqueInsets>
            <Insets />
        </opaqueInsets>
        <VBox.margin>
            <Insets bottom="24.0" />
        </VBox.margin>
    </Label>

    <DirectoryField fx:id="txtRomsPath" />
    <DirectoryField fx:id="txtRetroarchPath" />

    <HBox alignment="BOTTOM_RIGHT" prefHeight="29.0" prefWidth="504.0">
      <Button fx:id="btnGoBack" mnemonicParsing="false" prefHeight="30.0" prefWidth="103.0" text="Voltar">
         <HBox.margin>
            <Insets right="16.0" />
         </HBox.margin>
         <font>
            <Font name="Segoe UI" size="14.0" />
         </font></Button>
        <Button fx:id="btnSubmit" mnemonicParsing="false" prefHeight="30.0" prefWidth="103.0" text="Confirmar">
            <font>
                <Font size="14.0" />
            </font>
        </Button>

        <VBox.margin>
            <Insets top="64.0" />
        </VBox.margin>
    </HBox>

    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
</fx:root>
