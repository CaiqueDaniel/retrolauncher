<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.retrolauncher.gui.shared.components.DirectoryInput?>
<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>

<fx:root type="VBox" HBox.hgrow="ALWAYS" xmlns="http://javafx.com/javafx"
         xmlns:fx="http://javafx.com/fxml"
         prefHeight="400.0" prefWidth="600.0">
    <DirectoryInput text="Caminho da pasta do Retroarch" fx:id="txtRetroarchPath"/>
    <DirectoryInput text="Caminho da pasta de ROMs" fx:id="txtRomsPath"/>
    <Button mnemonicParsing="false" styleClass="primary" text="Salvar alterações" fx:id="btnSubmit">
        <font>
            <Font size="14.0"/>
        </font>
    </Button>
    <padding>
        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0"/>
    </padding>
</fx:root>
